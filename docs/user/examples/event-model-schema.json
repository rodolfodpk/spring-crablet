{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/crablet/spring-crablet/docs/examples/event-model-schema.json",
  "title": "EventModel",
  "description": "Schema for spring-crablet event-model.yaml files",
  "type": "object",
  "required": ["domain", "basePackage"],
  "additionalProperties": false,
  "properties": {
    "domain": {
      "type": "string",
      "description": "PascalCase domain name (e.g. Wallet, LoanApplication)"
    },
    "basePackage": {
      "type": "string",
      "description": "Java base package (e.g. com.example.wallet)",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z][a-z0-9]*)*$"
    },
    "schemas": {
      "type": "array",
      "description": "Reusable field groups shared across events and commands",
      "items": { "$ref": "#/$defs/SchemaSpec" },
      "default": []
    },
    "events": {
      "type": "array",
      "description": "Domain events (facts that have occurred)",
      "items": { "$ref": "#/$defs/EventSpec" },
      "default": []
    },
    "commands": {
      "type": "array",
      "description": "Commands that cause events to be appended",
      "items": { "$ref": "#/$defs/CommandSpec" },
      "default": []
    },
    "views": {
      "type": "array",
      "description": "Materialized read models updated by events",
      "items": { "$ref": "#/$defs/ViewSpec" },
      "default": []
    },
    "automations": {
      "type": "array",
      "description": "Event-driven policies that emit commands",
      "items": { "$ref": "#/$defs/AutomationSpec" },
      "default": []
    },
    "outbox": {
      "type": "array",
      "description": "Integration publishers for external event delivery",
      "items": { "$ref": "#/$defs/OutboxSpec" },
      "default": []
    },
    "deployment": {
      "$ref": "#/$defs/DeploymentSpec",
      "description": "Optional deployment topology for Kubernetes generation"
    },
    "diagram": {
      "$ref": "#/$defs/DiagramSpec",
      "description": "Optional renderer/tooling metadata — ignored by Java codegen"
    }
  },
  "$defs": {
    "FieldType": {
      "type": "string",
      "description": "JSON Schema type name or Crablet-specific type",
      "enum": ["string", "integer", "number", "boolean", "long", "UUID", "Instant", "array", "map"]
    },
    "FieldSpec": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "camelCase field name"
        },
        "type": {
          "$ref": "#/$defs/FieldType",
          "default": "string"
        },
        "minimum": {
          "type": "integer",
          "description": "Inclusive lower bound for integer/number fields"
        },
        "exclusiveMinimum": {
          "type": "integer",
          "description": "Exclusive lower bound for integer/number fields"
        },
        "maximum": {
          "type": "integer",
          "description": "Inclusive upper bound for integer/number fields"
        },
        "exclusiveMaximum": {
          "type": "integer",
          "description": "Exclusive upper bound for integer/number fields"
        },
        "minLength": {
          "type": "integer",
          "minimum": 0,
          "description": "Minimum string length (minLength: 1 means non-blank)"
        },
        "maxLength": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum string length"
        },
        "items": {
          "$ref": "#/$defs/FieldSpec",
          "description": "Element type for array fields (type: array)"
        },
        "additionalProperties": {
          "$ref": "#/$defs/FieldSpec",
          "description": "Value type for map fields (type: map, keys are always string)"
        },
        "minItems": {
          "type": "integer",
          "minimum": 0,
          "description": "Minimum number of elements in an array or map"
        },
        "maxItems": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum number of elements in an array or map"
        }
      }
    },
    "SchemaSpec": {
      "type": "object",
      "required": ["name", "fields"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "PascalCase schema name"
        },
        "fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/FieldSpec" }
        }
      }
    },
    "EventSpec": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "PascalCase event name (past-tense verb phrase)"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "snake_case tag keys used for event-store filtering and DCB boundaries"
        },
        "fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/FieldSpec" },
          "description": "Event payload fields (no constraint keywords — events are facts)"
        },
        "schema": {
          "type": "string",
          "description": "Reference to a named schema to inline its fields"
        }
      }
    },
    "CommandSpec": {
      "type": "object",
      "required": ["name", "pattern", "produces"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "PascalCase command name (imperative verb phrase)"
        },
        "pattern": {
          "type": "string",
          "enum": ["idempotent", "commutative", "non-commutative"],
          "description": "DCB append pattern"
        },
        "produces": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Event type names this command can append"
        },
        "guardEvents": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Lifecycle precondition event names the command decision model must validate; independent of command pattern"
        },
        "fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/FieldSpec" },
          "description": "Command input fields with optional JSON Schema constraint keywords"
        },
        "schema": {
          "type": "string",
          "description": "Reference to a named schema to inline its fields (with constraints)"
        }
      }
    },
    "ViewSpec": {
      "type": "object",
      "required": ["name", "reads", "tag"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "PascalCase view name"
        },
        "reads": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Event type names that update this view"
        },
        "tag": {
          "type": "string",
          "description": "snake_case tag key used to route events to the correct view row"
        },
        "fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/FieldSpec" },
          "description": "Projected table columns"
        }
      }
    },
    "AutomationSpec": {
      "type": "object",
      "required": ["name", "triggeredBy", "emitsCommand"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "kebab-case automation handler name"
        },
        "triggeredBy": {
          "type": "string",
          "description": "Event type name that triggers the automation decision"
        },
        "emitsCommand": {
          "type": "string",
          "description": "Command type name to emit when the condition passes"
        },
        "condition": {
          "type": "string",
          "description": "Explicit condition expression evaluated against the trigger event and optional view row"
        },
        "readsView": {
          "type": "string",
          "description": "View name to read when the condition depends on accumulated state"
        }
      }
    },
    "OutboxSpec": {
      "type": "object",
      "required": ["name", "topic", "handles"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "PascalCase publisher name"
        },
        "topic": {
          "type": "string",
          "description": "Outbox topic name"
        },
        "handles": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Event type names this publisher can deliver"
        },
        "adapter": {
          "type": "string",
          "description": "Integration adapter type (smtp, kafka, http, etc.)"
        }
      }
    },
    "KedaSpec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "minReplicas": { "type": "integer", "minimum": 0, "default": 0 },
        "pollingInterval": { "type": "integer", "minimum": 1, "default": 30 }
      }
    },
    "DeploymentSpec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "topology": {
          "type": "string",
          "enum": ["monolith", "distributed"],
          "default": "monolith",
          "description": "Deployment topology — monolith (default) or distributed (separate pods per processor)"
        },
        "commandReplicas": {
          "type": "integer",
          "minimum": 1,
          "default": 2,
          "description": "Number of command-handler pod replicas"
        },
        "keda": { "$ref": "#/$defs/KedaSpec" }
      }
    },
    "LaneSpec": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id":    { "type": "string", "description": "Lane identifier used in assignments" },
        "label": { "type": "string", "description": "Display label for the lane header (defaults to id)" }
      }
    },
    "ActorSpec": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id":    { "type": "string", "description": "Actor id referenced by triggers[].actor" },
        "label": { "type": "string", "description": "Display label for the actor band header" }
      }
    },
    "TriggerSpec": {
      "type": "object",
      "required": ["name", "linkedCommand"],
      "additionalProperties": false,
      "properties": {
        "name":          { "type": "string", "description": "Trigger card label" },
        "linkedCommand": { "type": "string", "description": "Command name this trigger drives" },
        "actor":         { "type": "string", "description": "Optional actor id (diagram.actors[].id); omit for External row" }
      }
    },
    "SyntheticCommandSpec": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name":         { "type": "string", "description": "Command name used for lane assignments and automation emitsCommand references" },
        "displayLabel": { "type": "string", "description": "Label shown on the synthetic command card" },
        "note":         { "type": "string", "description": "Secondary text shown on the card (e.g. subdomain hint)" }
      }
    },
    "DiagramSpec": {
      "type": "object",
      "description": "Renderer-only overlay metadata. Java codegen ignores this section entirely.",
      "additionalProperties": true,
      "properties": {
        "actors": {
          "type": "array",
          "items": { "$ref": "#/$defs/ActorSpec" },
          "description": "Human actors for canonical Event Modeling boards (top bands); order is top-to-bottom"
        },
        "lanes": {
          "type": "array",
          "items": { "$ref": "#/$defs/LaneSpec" },
          "description": "Subsystem lanes; in blueprint-with-actors mode these apply to the bottom section only (horizontal swim-stack mode still uses partitions for columns)"
        },
        "assignments": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Map of element name → lane id"
        },
        "triggers": {
          "type": "array",
          "items": { "$ref": "#/$defs/TriggerSpec" },
          "description": "External trigger cards rendered above the command row"
        },
        "syntheticCommands": {
          "type": "array",
          "items": { "$ref": "#/$defs/SyntheticCommandSpec" },
          "description": "Diagram-only command cards for cross-domain automation targets"
        },
        "eventBadges": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Map of event name → badge label shown on the event card"
        },
        "automations": {
          "type": "array",
          "items": { "$ref": "#/$defs/AutomationSpec" },
          "description": "Diagram-only automation rows not present in the structural automations list"
        },
        "display": {
          "type": "object",
          "description": "Renderer header and glyph options; merged to top-level display for `EventModelRenderer`",
          "additionalProperties": true,
          "properties": {
            "publicationEdges": {
              "type": "boolean",
              "description": "If true, canonical actor boards draw dashed publication edges from outbox-handled events to the topic label (default false)"
            }
          }
        }
      }
    }
  }
}
